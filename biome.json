{
  "$schema": "https://biomejs.dev/schemas/2.2.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": ["**", "!node_modules", "!.next", "!dist", "!build"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },

  "linter": {
    "enabled": true,
    "rules": {
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedFunctionParameters": {
          "fix": "none",
          "level": "warn",
          "options": {}
        },
        "noUnusedVariables": {
          "fix": "none",
          "level": "warn",
          "options": {}
        }
      },
      "recommended": false,
      "suspicious": {
        "noConsole": {
          "fix": "none",
          "level": "info",
          "options": {
            "allow": ["info"]
          }
        }
      }
    },
    "domains": {
      "next": "recommended",
      "react": "recommended"
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              ":PACKAGE:",
              ":BLANK_LINE:",
              ["~/**"],
              ":BLANK_LINE:",
              ["./**"]
            ]
          }
        }
      }
    },
    "enabled": true
  }
}
