{
  "name": "mentoris",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "biome:check": "biome check --no-errors-on-unmatched --files-ignore-unknown=true"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.1.3",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "lint-staged": "12.3.2",
    "@biomejs/biome": "2.1.2",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "*.{ts,js,json}": [
      "pnpm biome:check"
    ]
  }
}