{
	"name": "mentoris",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "pnpm -r --parallel dev",
		"dev:web": "pnpm --filter @mentoris/web dev",
		"dev:api": "pnpm --filter @mentoris/api dev",
		"db:studio": "pnpm --filter @mentoris/api db:studio",
		"db:generate": "pnpm --filter @mentoris/api db:generate",
		"db:migrate": "pnpm --filter @mentoris/api db:migrate",
		"build": "pnpm -r build",
		"build:contracts": "pnpm --filter @mentoris/contracts build",
		"lint": "pnpm -r lint",
		"typecheck": "pnpm -r typecheck",
		"biome:check": "biome check --no-errors-on-unmatched --files-ignore-unknown=true",
		"format": "biome check . --write"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "11.1.3",
			"onFail": "download"
		}
	},
	"devDependencies": {
		"lint-staged": "12.3.2",
		"@biomejs/biome": "2.1.2",
		"typescript": "^6.0.2"
	},
	"lint-staged": {
		"*.{ts,js,json}": [
			"pnpm biome:check"
		]
	}
}
