{
	"name": "backend",
	"version": "0.1.0-alpha",
	"main": "./src/app.ts",
	"type": "module",
	"license": "MIT",
	"scripts": {
		"dev": "tsx --watch --env-file .env ./src/app.ts",
		"build": "yarn build:emails && tsc && tsc-alias -p tsconfig.json && cp -R src/modules/email/templates dist/modules/email/templates",
		"start": "node dist/app.js",
		"build:emails": "tsx ./src/scripts/build-email-templates.ts",
		"typecheck": "tsc --noEmit",
		"biome:check": "biome check --no-errors-on-unmatched --files-ignore-unknown=true",
		"pre-commit": "lint-staged && yarn typecheck",
		"pre-push": "yarn typecheck && yarn biome:check",
		"db:generate": "drizzle-kit generate --name",
		"db:push": "drizzle-kit push",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"prepare": "husky install"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.922.0",
		"@fastify/cookie": "^11.0.2",
		"@fastify/cors": "^11.1.0",
		"@fastify/jwt": "^10.0.0",
		"@fastify/multipart": "^9.3.0",
		"@fastify/swagger": "^9.7.0",
		"@fastify/swagger-ui": "^5.2.5",
		"bcrypt": "^6.0.0",
		"better-auth": "^1.6.11",
		"dotenv": "^17.2.1",
		"drizzle-orm": "^0.44.2",
		"drizzle-zod": "^0.8.3",
		"fastify": "^5.4.0",
		"fastify-plugin": "^5.0.1",
		"fastify-type-provider-zod": "^6.1.0",
		"handlebars": "^4.7.8",
		"nodemailer": "^7.0.6",
		"pg": "^8.16.3",
		"tsc-alias": "^1.8.16",
		"uuid": "^11.1.0",
		"zod": "^4.0.5"
	},
	"devDependencies": {
		"@biomejs/biome": "2.1.2",
		"@types/bcrypt": "^5.0.2",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/mjml": "^4.7.4",
		"@types/node": "^25.6.0",
		"@types/nodemailer": "^7.0.1",
		"@types/pg": "^8.15.5",
		"drizzle-kit": "^0.31.4",
		"husky": "^8.0.0",
		"lint-staged": "12.3.2",
		"mjml": "^4.16.1",
		"tsx": "^4.20.3",
		"typescript": "^6.0.2"
	},
	"lint-staged": {
		"*.{ts,js,json}": [
			"yarn biome:check"
		]
	},
	"resolutions": {
		"@fastify/static": "9.1.0"
	}
}
