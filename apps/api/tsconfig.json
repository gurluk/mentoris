{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "rootDir": "./src",
    "outDir": "./dist",
    "types": ["node"],
    "allowArbitraryExtensions": true,
    "moduleDetection": "force",
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  "tsc-alias": {
    "verbose": false,
    "resolveFullPaths": true,
    "resolveFullExtension": ".js"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "src/db/migrations"]
}